APP_NAME="Chalet MVP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost:8000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chalet_mvp
DB_USERNAME=chalet
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@chalet.local"
MAIL_FROM_NAME="${APP_NAME}"

# Rate limiting (used for inquiry spam protection)
INQUIRY_RATE_LIMIT_PER_MINUTE=10

# Admin credentials (used by AdminSeeder on first migrate:fresh --seed)
# ⚠️  CHANGE THESE BEFORE GOING TO PRODUCTION!
# Default values let you log in immediately during local development.
ADMIN_NAME="مدير الشاليه"
ADMIN_EMAIL=admin@chalet.local
ADMIN_PASSWORD=changeme

# Inertia SSR (disabled for MVP; keep off unless deploying with Node SSR)
INERTIA_SSR_ENABLED=false

VITE_APP_NAME="${APP_NAME}"