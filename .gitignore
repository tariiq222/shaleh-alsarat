/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
.env
.env.backup
.env.production
.env.local
.phpactor.json
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
/.fleet
/.idea
/.vscode
/.zed

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# OS files
.DS_Store
Thumbs.db

# Logs
/storage/logs/*.log

# Local DB dumps (if any)
/database/*.sql
/backups/

# Local SQLite DB (development only)
/database/database.sqlite

# Bootstrap framework cache (generated at runtime)
/bootstrap/cache/*.php
!/bootstrap/cache/.gitkeep

# Compiled Blade templates (cached at runtime)
/storage/framework/views/*.php
!/storage/framework/views/.gitkeep

# Composer lock is committed (ensures reproducible installs)
!composer.lock
