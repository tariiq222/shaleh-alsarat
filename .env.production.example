# =====================================================
# Production .env for shaleh-alsarat (Docker deployment)
# =====================================================
# Copy this file to `.env` on the server, then fill in
# every value below. NEVER commit `.env` to git.
# =====================================================

# ---- Laravel ----
APP_NAME="شاليهات السراة"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Riyadh
APP_LOCALE=ar

# 32-char base64 key. Generated automatically on first container start.
APP_KEY=

# ---- Database (external PostgreSQL) ----
DB_CONNECTION=pgsql

# OPTION A: Single URL (simplest — supported by Supabase, Neon, Render, etc.)
# postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=

# OPTION B: Individual fields (uncomment + set, comment DATABASE_URL instead):
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=require

# ---- Admin user (created on first container boot) ----
ADMIN_NAME="مدير الشاليه"
ADMIN_EMAIL=admin@your-domain.com

# Use a STRONG password (will be hashed by AdminSeeder).
ADMIN_PASSWORD=

# ---- Cache / Sessions / Queue ----
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ---- Filesystem ----
FILESYSTEM_DISK=public

# ---- Logging ----
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ---- SMTP (optional, for future email features) ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
