# =====================================================
# Production .env for shaleh-alsarat (Docker deployment)
# =====================================================
# Copy this file to `.env` on the server, then fill in
# every value below. NEVER commit `.env` to git.
# =====================================================

# ---- Laravel ----
APP_NAME="شاليهات السراة"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Riyadh
APP_LOCALE=ar

# 32-char base64 key. Generate with:
#   php artisan key:generate --show
# (Or it'll be generated automatically on first container start.)
APP_KEY=

# ---- Database (matches docker-compose.yml) ----
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=chalet_mvp
DB_USERNAME=chalet

# Use a STRONG password — at least 16 random characters.
# Generate: openssl rand -base64 24 | tr -d '=+/' | head -c 24
DB_PASSWORD=

# MySQL root password (only used by docker-compose on first init)
DB_ROOT_PASSWORD=

# ---- Admin user (created on first container boot) ----
ADMIN_NAME="مدير الشاليه"
ADMIN_EMAIL=admin@your-domain.com

# Use a STRONG password (will be hashed by AdminSeeder).
ADMIN_PASSWORD=

# ---- Cache / Sessions / Queue ----
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ---- Filesystem ----
FILESYSTEM_DISK=public

# ---- Logging ----
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ---- SMTP (optional, for future email features) ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
